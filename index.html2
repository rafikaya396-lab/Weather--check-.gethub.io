<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LearnFlow - Language Learning Pro</title>
    <style>
        :root {
            --bg-overlay: rgba(0,0,0,0.7);
            --card-bg: rgba(0,0,0,0.6);
            --accent: #ff7f50;
            --accent-hover: #ff4500;
            --text: #fff;
        }
        
        body.light {
            --bg-overlay: rgba(255,255,255,0.8);
            --card-bg: rgba(255,255,255,0.9);
            --text: #111;
            color: #111;
        }

        body {
            font-family: 'Poppins', Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: url('https://images.unsplash.com/photo-1519681393784-d120267933ba') no-repeat center center fixed;
            background-size: cover;
            color: var(--text);
            transition: all 0.3s ease;
        }
        
        nav {
            background-color: var(--bg-overlay);
            padding: 15px 10px;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
        }
        nav a {
            color: var(--text);
            margin: 0 12px;
            text-decoration: none;
            font-weight: bold;
            font-size: 16px;
        }
        nav a:hover {
            color: var(--accent);
        }
        #themeToggle, #userBtn {
            padding: 8px 15px;
            border: none;
            border-radius: 8px;
            background: var(--accent);
            color: #fff;
            cursor: pointer;
            margin: 0 5px;
        }
        
        .hero {
            text-align: center;
            padding: 80px 20px 40px;
            animation: fadeIn 2s;
        }
        .hero h1 {
            font-size: 48px;
            margin-bottom: 20px;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.7);
        }
        .hero button {
            padding: 15px 30px;
            font-size: 20px;
            cursor: pointer;
            border: none;
            border-radius: 10px;
            background: var(--accent);
            color: #fff;
            transition: 0.3s;
        }
        .hero button:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
        }
        
        .word-day {
            background: var(--card-bg);
            max-width: 400px;
            margin: 20px auto;
            padding: 20px;
            border-radius: 15px;
            border: 2px solid var(--accent);
        }
        
        .user-stats {
            background: var(--card-bg);
            max-width: 300px;
            margin: 20px auto;
            padding: 15px;
            border-radius: 15px;
            text-align: center;
        }
        
        .progress-bar {
            width: 100%;
            height: 8px;
            background: rgba(255,255,255,0.3);
            border-radius: 4px;
            margin-top: 8px;
        }
        .progress-fill {
            height: 100%;
            background: var(--accent);
            border-radius: 4px;
            width: 0%;
            transition: width 0.5s ease;
        }
        
        .languages {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            margin: 30px 0;
            padding: 0 20px;
        }
        .language-card {
            background: var(--card-bg);
            margin: 20px;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            width: 320px;
            transition: transform 0.3s, box-shadow 0.3s;
            backdrop-filter: blur(5px);
        }
        .language-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }
        .language-card img {
            width: 80px;
            height: 80px;
            margin-bottom: 15px;
            border-radius: 50%;
        }
        .language-card h2 {
            margin: 10px 0;
        }
        
        .quiz button, .speak-btn {
            padding: 8px 15px;
            margin: 5px;
            border: none;
            border-radius: 8px;
            background: var(--accent);
            color: #fff;
            cursor: pointer;
            transition: 0.2s;
        }
        .quiz button:hover, .speak-btn:hover {
            background: var(--accent-hover);
            transform: scale(1.05);
        }
        
        .chat-sim {
